# ========= Project-wide ignores (MERN) =========
# Root: New_Blood_Donation/

# ── Dependencies ─────────────────────────────────
/frontend/node_modules/
/backend/node_modules/
node_modules/

# ── Builds / output ──────────────────────────────
/frontend/dist/
/frontend/dist-ssr/
/frontend/build/
/backend/dist/
/backend/build/

# ── Logs ─────────────────────────────────────────
/frontend/logs/
/backend/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Environment files (never commit secrets) ─────
/frontend/.env
/frontend/.env.*
/backend/.env
/backend/.env.*
*.local
.env
.env.local
.env.*.local

# ── Firebase Secrets (CRITICAL) ──────────────────
backend/firebaseServiceAccountKey.json

# ── Uploads / generated files ────────────────────
/backend/uploads/

# ── OS ───────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE / editor ─────────────────────────────────
/.vscode/
!/.vscode/extensions.json
/.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.vite/

